# --- Source / IO ---
SRC=0
YOLO_MODEL=yolov8n.pt
YOLO_ENGINE=yolov8n.engine
IMG_SIZE=640
CONF_THRESH=0.60
VID_STRIDE=1
SAVE_DIR=/workspace/work/alerts
DRAW=1

# --- Presence / Tracking / Alerts ---
TRIGGER_CLASSES=person,dog,cat
DRAW_CLASSES=person,car,dog,cat,motorcycle
MIN_FRAMES=3
MIN_PERSIST_SEC=1
REARM_SEC=20
RATE_WINDOW_SEC=30
# Min seconds between any two alerts (stops same person with new track_id from re-triggering; 0 = use RATE_WINDOW_SEC only)
ALERT_COOLDOWN_SEC=150
TRACKER=botsort.yaml

# --- Adaptive Rate (new modular pipeline) ---
BASE_FPS=5
HIGH_FPS=0           # 0 = uncapped
BOOST_ARM_FRAMES=3
BOOST_MIN_SEC=1
COOLDOWN_SEC=5.0

USE_GSTREAMER=0
RTSP_LATENCY_MS=200
CAP_PROP_BUFFERSIZE=2


# --- Optional zone polygon (x,y;x,y;...) ---
ZONE=
# --- Telegram (optional) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# Optional Telegram Q&A poller tuning
TG_QA_ALLOWED_CHAT_ID=
TG_QA_POLL_TIMEOUT_SEC=25
TG_QA_IDLE_SLEEP_SEC=1

# --- Alert history / LLM Q&A ---
ALERT_DB_PATH=/workspace/work/alerts/alert_history.db
LLM_PROVIDER=none
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1


