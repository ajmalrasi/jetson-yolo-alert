# --- Source / IO ---
SRC=0
YOLO_MODEL=yolov8n.pt
YOLO_ENGINE=yolov8n.engine
IMG_SIZE=640
CONF_THRESH=0.60
VID_STRIDE=1
SAVE_DIR=/workspace/work/alerts
DRAW=1
# Save clean (un-annotated) frames for fine-tuning / labeling
SAVE_RAW_FRAMES=0
RAW_FRAMES_DIR=/workspace/work/raw_frames

# --- Presence / Tracking / Alerts ---
TRIGGER_CLASSES=person,dog,cat
DRAW_CLASSES=person,car,dog,cat,motorcycle
MIN_FRAMES=3
MIN_PERSIST_SEC=1
REARM_SEC=20
RATE_WINDOW_SEC=30
# Min seconds between any two alerts (stops same person with new track_id from re-triggering; 0 = use RATE_WINDOW_SEC only)
ALERT_COOLDOWN_SEC=150
TRACKER=botsort.yaml

# --- Adaptive Rate (new modular pipeline) ---
BASE_FPS=5
HIGH_FPS=0           # 0 = uncapped
BOOST_ARM_FRAMES=3
BOOST_MIN_SEC=1
COOLDOWN_SEC=5.0

USE_GSTREAMER=0
RTSP_LATENCY_MS=200
# Low latency: 1 (default in code). Raise to 2 if RTSP/USB is unstable.
CAP_PROP_BUFFERSIZE=1
# Optional: grab N times without full decode before read() — shrinks lag when inference is slower than camera FPS (try 4–16).
# CAMERA_GRAB_FLUSH=0

# --- Preview: MJPEG (post-detection boxes) from another PC ---
# Required for headless Docker (no DISPLAY); OpenCV GUI is skipped automatically.
# PREVIEW_STREAM_PORT=8080
# PREVIEW_STREAM_BIND=0.0.0.0
# PREVIEW_STREAM_MAX_WIDTH=1280
# PREVIEW_STREAM_QUALITY=82
# PREVIEW_STREAM_FPS=25
# PREVIEW_USE_DISPLAY=0   # force no imshow even if DISPLAY is set (stream-only)
# PREVIEW_DETECTOR_ONLY=1 # preview only: max throughput, no alert/DB/snapshots; track IDs on stream; does NOT stop docker alert service

# --- Telemetry (bottleneck timings; see docs/metrics.md) ---
# TELEMETRY_BACKEND=log
# TELEMETRY_LOG_LEVEL=INFO
# TELEMETRY_BACKEND=otlp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=jetson-yolo-alert
# OTEL_METRICS_PREFIX=jetson_yolo

# --- Optional zone polygon (x,y;x,y;...) ---
ZONE=
# --- Telegram (optional) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# Restrict which Telegram chat can use the /ask Q&A bot (optional)
TG_QA_ALLOWED_CHAT_ID=

# --- Alert history / LLM Q&A ---
ALERT_DB_PATH=/workspace/work/alerts/alert_history.db
# litellm model string — provider/model (uncomment ONE):
#   groq/llama-3.3-70b-versatile (needs GROQ_API_KEY, free tier — recommended)
#   groq/llama-3.1-8b-instant    (needs GROQ_API_KEY, free tier — faster but less accurate)
#   openai/gpt-4o-mini           (needs OPENAI_API_KEY)
#   xai/grok-2-latest            (needs XAI_API_KEY)
#   ollama/llama3                 (local, needs OLLAMA_API_BASE)
LLM_MODEL=groq/llama-3.3-70b-versatile
# Provider API keys — only the one matching your LLM_MODEL is needed:
OPENAI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
# Enable QA debug trace logging (writes to SAVE_DIR/qa_trace.log)
QA_DEBUG=1
